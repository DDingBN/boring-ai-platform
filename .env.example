# 本地开发的安全默认配置。
# 复制为 .env 后按需修改；当前项目启动不需要任何 API 密钥。

NODE_ENV=development

# API 服务：默认仅允许本机访问。
SERVER_HOST=127.0.0.1
SERVER_PORT=3001

# Web 开发服务：默认仅允许本机访问。
WEB_HOST=127.0.0.1
WEB_PORT=5173

# 当前支持的模型提供商。未知值会在后端启动前被拒绝。
AI_PROVIDER=deepseek

# 数据库接入前可留空；设置后必须是 postgresql://、postgres://、mysql:// 或 file: URL。
DATABASE_URL=

# DeepSeek 仅由后端读取。请只在 .env 文件中填入真实值，不要加 VITE_ 前缀。
DEEPSEEK_API_KEY=
